diff --git a/hw/xquartz/X11Controller.m b/hw/xquartz/X11Controller.m
index e21aed0d3..1ef5f4031 100644
--- a/hw/xquartz/X11Controller.m
+++ b/hw/xquartz/X11Controller.m
@@ -57,6 +57,16 @@
 extern aslclient aslc;
 extern char *bundle_id_prefix;
 
+NSTimeInterval xquartz_last_wake_time = 0;
+
+Bool XQuartzIsWaking(void) {
+    if (xquartz_last_wake_time == 0) return FALSE;
+    if ([NSDate timeIntervalSinceReferenceDate] - xquartz_last_wake_time < 5.0) {
+        return TRUE;
+    }
+    return FALSE;
+}
+
 @interface X11Controller ()
 #ifdef XQUARTZ_SPARKLE
 @property (nonatomic, readwrite, strong) NSMenuItem *check_for_updates_item; // Programatically enabled
@@ -79,6 +89,11 @@ extern char *bundle_id_prefix;
     /* Point X11Application at ourself. */
     xapp.controller = self;
 
+    [NSWorkspace.sharedWorkspace.notificationCenter addObserver:self
+                                                       selector:@selector(workspaceDidWake:)
+                                                           name:NSWorkspaceDidWakeNotification
+                                                         object:nil];
+
     NSUserDefaults * const defaults = NSUserDefaults.xquartzDefaults;
     NSArray *appsMenu = [defaults arrayForKey:XQuartzPrefKeyAppsMenu];
 
@@ -828,6 +843,13 @@ extern char *bundle_id_prefix;
         return TRUE;
 }
 
+- (void)workspaceDidWake:(NSNotification *)note {
+    xquartz_last_wake_time = [NSDate timeIntervalSinceReferenceDate];
+    dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(5.0 * NSEC_PER_SEC)), dispatch_get_main_queue(), ^{
+        DarwinSendDDXEvent(kXquartzDisplayChanged, 0);
+    });
+}
