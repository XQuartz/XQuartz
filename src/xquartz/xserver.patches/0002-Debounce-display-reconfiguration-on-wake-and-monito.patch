 extern aslclient aslc;
 extern char *bundle_id_prefix;

+#include <pthread.h>
+#include <stdint.h>
+
+/*
+ * Coalesce bursts of kXquartzDisplayChanged events -- both waking from sleep
+ * and monitor/arrangement changes fire several of these in quick succession
+ * while macOS renegotiates the display layout -- into a single deferred
+ * screen update, instead of repositioning windows mid-transition.
+ *
+ * This state is written from the AppKit main thread (workspaceDidWake:/
+ * screenParametersDidChange:) and read/extended from the X server's own
+ * thread inside DarwinEventHandler() in darwinEvents.c, so it needs real
+ * locking rather than a bare global; pthread_mutex_t mirrors what
+ * darwinEvents.c already uses for its own cross-thread state (fd_add_lock).
+ */
+#define XQUARTZ_RECONFIG_DEBOUNCE_SECONDS 5.0
+#define XQUARTZ_RECONFIG_MAX_WAIT_SECONDS 15.0
+
+static pthread_mutex_t xquartz_reconfig_lock = PTHREAD_MUTEX_INITIALIZER;
+static uint64_t xquartz_reconfig_generation = 0;
+static NSTimeInterval xquartz_reconfig_window_start = 0;
+static Bool xquartz_reconfig_active = FALSE;
+
+Bool XQuartzDisplayReconfigDebounceActive(void)
+{
+    pthread_mutex_lock(&xquartz_reconfig_lock);
+    Bool active = xquartz_reconfig_active;
+    pthread_mutex_unlock(&xquartz_reconfig_lock);
+    return active;
+}
+
+/* Open (or extend) the debounce window. Safe to call from either thread. */
+void XQuartzDisplayReconfigDebounce(void)
+{
+    NSTimeInterval now = [NSDate timeIntervalSinceReferenceDate];
+    uint64_t generation;
+    NSTimeInterval delay;
+
+    pthread_mutex_lock(&xquartz_reconfig_lock);
+    generation = ++xquartz_reconfig_generation;
+    if (!xquartz_reconfig_active) {
+        xquartz_reconfig_active = TRUE;
+        xquartz_reconfig_window_start = now;
+    }
+    /* Force a flush once we've been suppressing for too long, so a display
+     * that never settles (e.g. a flapping connection) can't starve updates
+     * forever.
+     */
+    delay = (now - xquartz_reconfig_window_start >= XQUARTZ_RECONFIG_MAX_WAIT_SECONDS) ?
+            0.0 : XQUARTZ_RECONFIG_DEBOUNCE_SECONDS;
+    pthread_mutex_unlock(&xquartz_reconfig_lock);
+
+    dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(delay * NSEC_PER_SEC)),
+                   dispatch_get_main_queue(), ^{
+        Bool shouldFlush = FALSE;
+
+        pthread_mutex_lock(&xquartz_reconfig_lock);
+        if (xquartz_reconfig_generation == generation) {
+            xquartz_reconfig_active = FALSE;
+            shouldFlush = TRUE;
+        }
+        pthread_mutex_unlock(&xquartz_reconfig_lock);
+
+        if (shouldFlush)
+            DarwinSendDDXEvent(kXquartzDisplayChanged, 0);
+    });
+}
